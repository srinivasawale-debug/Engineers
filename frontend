let leafletMap = null;
// --- Initialization ---
document.addEventListener('DOMContentLoaded', () => {
    // Show home by default
    showSection('home');
    
    // Check local storage for persistence
    const storedJobs = localStorage.getItem('rozgar_jobs');
    const storedWorkers = localStorage.getItem('rozgar_workers');
    if (storedJobs) jobs = JSON.parse(storedJobs);
    if (storedWorkers) workers = JSON.parse(storedWorkers);
    // Initial render
    displayJobs();
    displayWorkers();
    // Event Listeners for Forms
    document.getElementById('registerForm').addEventListener('submit', handleRegisterSubmit);
    document.getElementById('postJobForm').addEventListener('submit', handlePostJobSubmit);
    document.getElementById('filterForm').addEventListener('submit', filterJobs);
});
// --- Navigation Logic ---
/**
 * showSection()
 * Hides all sections and displays the target one. Handles map resizing.
 */
function showSection(sectionId) {
    // Hide all sections
    document.querySelectorAll('.view-section').forEach(sec => {
        sec.classList.add('d-none');
        sec.classList.remove('d-flex'); // specifically for map flex layout
    });
    // Handle map class specifics
    const targetSection = document.getElementById(sectionId);
    if(sectionId === 'map') {
        targetSection.classList.remove('d-none'); // CSS handles flex
        setTimeout(() => {
            initMap(); // Init or invalidate size
        }, 100);
    } else {
        targetSection.classList.remove('d-none');
    }
    
    // Update nav links
    document.querySelectorAll('.nav-link').forEach(link => {
        link.classList.remove('active', 'fw-bold');
    });
    
    // Find the link that triggered this (exact match of string)
    const clickedLinks = Array.from(document.querySelectorAll('.nav-link')).filter(link => 
        link.getAttribute('onclick').includes(`'${sectionId}'`)
    );
    clickedLinks.forEach(link => link.classList.add('active', 'fw-bold'));
    
    // Re-render specifics to ensure fresh data
    if (sectionId === 'findJobs') displayJobs();
    if (sectionId === 'workers') displayWorkers();
    
    window.scrollTo(0,0);
}
// --- Worker Registration ---
/**
 * registerWorker()
 * Handles adding new workers to the directory and saving state.
 */
function handleRegisterSubmit(e) {
    e.preventDefault();
    
    const name = document.getElementById('workerName').value;
    const phone = document.getElementById('workerPhone').value;
    const skill = document.getElementById('workerSkill').value;
    const rating = parseFloat(document.getElementById('workerRating').value);
    const location = document.getElementById('workerLocation').value;
    
    // Mock geocoding by slightly randomizing around a central point, or using defaults
    // Since this is a prototype, we just add a small offset to India's center
    const lat = 20.5937 + (Math.random() - 0.5) * 5;
    const lng = 78.9629 + (Math.random() - 0.5) * 5;
    const newWorker = {
        id: Date.now(),
        name,
        phone,
        skill,
        rating,
        location,
        verified: true, // Auto verify for this prototype scope
        coords: [lat, lng]
    };
    
    // Add to top of list
    workers.unshift(newWorker);
    localStorage.setItem('rozgar_workers', JSON.stringify(workers));
    
    // Cleanup
    document.getElementById('registerForm').reset();
    
    alert(`Registration Successful! Welcome to RozgarSaathi, ${name}. You are now visible to employers.`);
    showSection('workers');
    
    // Update map if it's already initialized
    if(leafletMap) {
        initMap();
    }
}
// --- Job Posting ---
/**
 * postJob()
 * Adds new job to the jobs list.
 */
function handlePostJobSubmit(e) {
    e.preventDefault();
    
    const newJob = {
        id: Date.now(),
        title: document.getElementById('jobTitle').value,
        skill: document.getElementById('jobSkill').value,
        location: document.getElementById('jobLocation').value,
        description: document.getElementById('jobDescription').value,
        phone: document.getElementById('jobPhone').value,
        urgency: document.getElementById('jobUrgency').value,
        date: new Date().toISOString()
    };
    
    jobs.unshift(newJob);
    localStorage.setItem('rozgar_jobs', JSON.stringify(jobs));
    
    document.getElementById('postJobForm').reset();
    
    alert("Job posted successfully! Workers can now find and contact you.");
    showSection('findJobs');
}
// --- Jobs Filtering ---
/**
 * filterJobs()
 * Calls displayJobs which respects the current filter states.
 */
function filterJobs(e) {
    if(e) e.preventDefault();
    displayJobs();
}
// --- UI Rendering ---
/**
 * displayJobs()
 * Renders job cards to the DOM.
 */
function displayJobs() {
    const filterSkill = document.getElementById('filterSkill').value;
    const filterLocation = document.getElementById('filterLocation').value.toLowerCase();
    
    const container = document.getElementById('jobListings');
    const noJobsMsg = document.getElementById('noJobsMessage');
    
    container.innerHTML = '';
    
    const filteredJobs = jobs.filter(job => {
        const matchSkill = filterSkill === 'All' || job.skill === filterSkill;
        const matchLocation = filterLocation === '' || job.location.toLowerCase().includes(filterLocation);
        return matchSkill && matchLocation;
    });
    
    if (filteredJobs.length === 0) {
        noJobsMsg.classList.remove('d-none');
    } else {
        noJobsMsg.classList.add('d-none');
        filteredJobs.forEach(job => {
            const card = document.createElement('div');
            card.className = 'col';
            
            const waMessage = encodeURIComponent(`Hello, I am a worker interested in the job: "${job.title}" you posted on RozgarSaathi.`);
            const waLink = `https://wa.me/91${job.phone}?text=${waMessage}`;
            
            const isUrgent = job.urgency === 'Urgent';
            const urgencyBadgeClass = isUrgent ? 'bg-danger text-white' : 'bg-light text-dark border';
            const urgencyIcon = isUrgent ? '<i class="bi bi-lightning-fill text-warning me-1"></i>' : '';
            
            card.innerHTML = `
                <div class="card h-100 shadow-sm border-0 job-card rounded-4 overflow-hidden">
                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge skill-badge rounded-pill">${job.skill}</span>
                            <span class="badge ${urgencyBadgeClass} urgency-badge">${urgencyIcon}${job.urgency}</span>
                        </div>
                        <h5 class="card-title fw-bold mb-3">${job.title}</h5>
                        <h6 class="card-subtitle mb-3 text-muted">
                            <i class="bi bi-geo-alt-fill text-primary me-2"></i>${job.location}
                        </h6>
                        <p class="card-text text-secondary mb-4 flex-grow-1">${job.description}</p>
                        
                        <a href="${waLink}" target="_blank" class="btn whatsapp-btn w-100 rounded-pill py-2 mt-auto">
                            <i class="bi bi-whatsapp me-2"></i>Contact on WhatsApp
                        </a>
                    </div>
                </div>
            `;
            container.appendChild(card);
        });
    }
}
/**
 * displayWorkers()
 * Renders worker directory cards.
 */
function displayWorkers() {
    const container = document.getElementById('workerListings');
    const noWorkersMsg = document.getElementById('noWorkersMessage');
    
    container.innerHTML = '';
    
    if (workers.length === 0) {
        noWorkersMsg.classList.remove('d-none');
    } else {
        noWorkersMsg.classList.add('d-none');
        workers.forEach(worker => {
            const card = document.createElement('div');
            card.className = 'col';
            
            const waMessage = encodeURIComponent(`Hello ${worker.name}, I found your profile on RozgarSaathi and have an opportunity for you.`);
            const waLink = `https://wa.me/91${worker.phone}?text=${waMessage}`;
            
            // Create initials avatar
            const initials = worker.name.split(' ').map(n=>n[0]).join('').substring(0,2).toUpperCase();
            
            // Create rating stars
            const fullStars = Math.floor(worker.rating);
            const halfStar = worker.rating % 1 >= 0.5 ? 1 : 0;
            const emptyStars = 5 - fullStars - halfStar;
            
            let starsHtml = '';
            for(let i=0; i<fullStars; i++) starsHtml += '<i class="bi bi-star-fill text-warning"></i> ';
            if(halfStar) starsHtml += '<i class="bi bi-star-half text-warning"></i> ';
            for(let i=0; i<emptyStars; i++) starsHtml += '<i class="bi bi-star text-warning"></i> ';
            
            card.innerHTML = `
                <div class="card h-100 shadow-sm border-0 worker-card rounded-4">
                    <div class="card-body p-4 text-center d-flex flex-column">
                        <div class="d-flex justify-content-center mb-3 position-relative">
                            <div class="worker-avatar-placeholder">${initials}</div>
                        </div>
                        
                        <h5 class="card-title fw-bold mb-1">${worker.name}</h5>
                        
                        <div class="mb-2">
                            <span class="badge bg-light text-primary border rounded-pill px-3">${worker.skill}</span>
                        </div>
                        
                        <div class="mb-3">
                            ${starsHtml} <span class="text-muted small ms-1">(${worker.rating})</span>
                        </div>
                        
                        <p class="mb-2 text-muted small"><i class="bi bi-geo-alt-fill text-danger me-1"></i> ${worker.location}</p>
                        
                        <div class="mt-3 mb-4">
                            <span class="badge-verified">Verified Worker</span>
                        </div>
                        
                        <div class="mt-auto">
                            <a href="${waLink}" target="_blank" class="btn btn-outline-success w-100 rounded-pill fw-bold">
                                <i class="bi bi-whatsapp me-2"></i>Hire Worker
                            </a>
                        </div>
                    </div>
                </div>
            `;
            container.appendChild(card);
        });
    }
}
/**
 * initMap()
 * Initializes Leaflet Map and plots worker markers.
 */
function initMap() {
    const mapCenter = [20.5937, 78.9629]; // Default center (India roughly)
    const mapZoom = 5;
    // If map already exists, just invalidate size so it fits the container correctly
    if (leafletMap) {
        leafletMap.invalidateSize();
        
        // Clear old markers
        leafletMap.eachLayer((layer) => {
            if (layer instanceof L.Marker) {
                leafletMap.removeLayer(layer);
            }
        });
    } else {
        // Create map instace
        leafletMap = L.map('mapContainer').setView(mapCenter, mapZoom);
        // Add OSM tiles
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
        }).addTo(leafletMap);
    }
    // Add markers for each worker
    if (workers && workers.length > 0) {
        
        // Define a custom icon (optional, using default here but adding popup classes)
        workers.forEach(worker => {
            if(worker.coords && worker.coords.length === 2) {
                const waLink = `https://wa.me/91${worker.phone}`;
                const popupContent = `
                    <div class="text-center p-1">
                        <h6 class="fw-bold mb-1">${worker.name}</h6>
                        <span class="badge bg-primary mb-2">${worker.skill}</span><br>
                        <small class="text-muted d-block mb-2">⭐ ${worker.rating}</small>
                        <a href="${waLink}" target="_blank" class="btn btn-sm btn-success rounded-pill" style="font-size: 0.75rem;">
                            Contact
                        </a>
                    </div>
                `;
                
                L.marker([worker.coords[0], worker.coords[1]])
                    .addTo(leafletMap)
                    .bindPopup(popupContent);
            }
        });
        
        // Auto fit bounds to markers if we have workers with coordinates
        const validCoords = workers.filter(w => w.coords).map(w => w.coords);
        if(validCoords.length > 0) {
            leafletMap.fitBounds(validCoords, { padding: [50, 50], maxZoom: 12 });
        }
    }
}
