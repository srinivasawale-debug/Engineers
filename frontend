<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RozgarSaathi - Connect with Local Work</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#" onclick="showSection('home')">RozgarSaathi</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#" onclick="showSection('home')">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" onclick="showSection('register')">Register Worker</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" onclick="showSection('postJob')">Post Job</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" onclick="showSection('findJobs')">Find Jobs</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" onclick="showSection('workers')">Workers List</a></li>
                </ul>
            </div>
        </div>
    </nav>
    <div class="container mt-4 mb-5">
        <!-- Home Section -->
        <section id="home" class="view-section">
            <div class="p-5 mb-4 bg-light rounded-3 text-center hero-section">
                <div class="container-fluid py-5">
                    <h1 class="display-5 fw-bold text-primary">Welcome to RozgarSaathi</h1>
                    <p class="col-md-8 mx-auto fs-4">A hyperlocal platform connecting daily wage workers with households for same-day work.</p>
                    <button class="btn btn-primary btn-lg mt-3 me-2" onclick="showSection('findJobs')">Find a Job</button>
                    <button class="btn btn-outline-primary btn-lg mt-3" onclick="showSection('postJob')">Post a Job</button>
                </div>
            </div>
            
            <div class="row text-center mt-5">
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm p-3">
                        <div class="card-body">
                            <i class="bi bi-shield-check fs-1 text-success mb-3"></i>
                            <h3 class="card-title text-success">Verified Workers</h3>
                            <p class="card-text">All workers are Aadhaar verified for your safety and peace of mind.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm p-3">
                        <div class="card-body">
                            <i class="bi bi-whatsapp fs-1 text-info mb-3"></i>
                            <h3 class="card-title text-info">Instant Connect</h3>
                            <p class="card-text">Connect directly on WhatsApp, no middlemen or platform fees involved.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm p-3">
                        <div class="card-body">
                            <i class="bi bi-geo-alt fs-1 text-warning mb-3"></i>
                            <h3 class="card-title text-warning">Local Work</h3>
                            <p class="card-text">Find work or workers right in your own city or preferred pincode.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Register Worker Section -->
        <section id="register" class="view-section d-none">
            <h2 class="mb-4 text-center">Register as a Worker</h2>
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4 p-md-5">
                            <form id="registerForm">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Full Name</label>
                                    <input type="text" id="workerName" class="form-control form-control-lg" placeholder="Enter your full name" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Phone Number</label>
                                    <input type="tel" id="workerPhone" class="form-control form-control-lg" placeholder="10-digit mobile number" pattern="[0-9]{10}" maxlength="10" required>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold">Skill</label>
                                        <select id="workerSkill" class="form-select form-select-lg" required>
                                            <option value="">Select a skill...</option>
                                            <option value="Plumber">Plumber</option>
                                            <option value="Electrician">Electrician</option>
                                            <option value="Painter">Painter</option>
                                            <option value="Carpenter">Carpenter</option>
                                            <option value="Mazdoor">Mazdoor / Helper</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold">Location</label>
                                        <input type="text" id="workerLocation" class="form-control form-control-lg" placeholder="City or Pincode" required>
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-semibold">Availability</label>
                                    <select id="workerAvailability" class="form-select form-select-lg" required>
                                        <option value="Available Now">Available Now</option>
                                        <option value="Available Tomorrow">Available Tomorrow</option>
                                    </select>
                                </div>
                                <div class="mb-4 form-check bg-light p-3 rounded d-flex align-items-center">
                                    <input type="checkbox" class="form-check-input ms-1 me-3 fs-4 mt-0" id="aadhaarConsent" required>
                                    <label class="form-check-label" for="aadhaarConsent">
                                        I consent to platform verifying my identity using Aadhaar OTP.
                                    </label>
                                </div>
                                <button type="submit" class="btn btn-primary btn-lg w-100">Register & Verify Identity</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Post Job Section -->
        <section id="postJob" class="view-section d-none">
            <h2 class="mb-4 text-center">Post a Job</h2>
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4 p-md-5">
                            <form id="postJobForm">
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Job Title</label>
                                    <input type="text" id="jobTitle" class="form-control form-control-lg" placeholder="e.g., Need a plumber to fix bathroom sink" required>
                                </div>
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold">Required Skill</label>
                                        <select id="jobSkill" class="form-select form-select-lg" required>
                                            <option value="">Select needed skill...</option>
                                            <option value="Plumber">Plumber</option>
                                            <option value="Electrician">Electrician</option>
                                            <option value="Painter">Painter</option>
                                            <option value="Carpenter">Carpenter</option>
                                            <option value="Mazdoor">Mazdoor / Helper</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold">Location</label>
                                        <input type="text" id="jobLocation" class="form-control form-control-lg" placeholder="City or Pincode" required>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Job Description</label>
                                    <textarea id="jobDescription" class="form-control form-control-lg" rows="4" placeholder="Describe the work to be done..." required></textarea>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label fw-semibold">Contact Phone Number</label>
                                    <input type="tel" id="jobPhone" class="form-control form-control-lg" placeholder="10-digit mobile number for WhatsApp link" pattern="[0-9]{10}" maxlength="10" required>
                                    <div class="form-text">Workers will contact you on this number via WhatsApp.</div>
                                </div>
                                <button type="submit" class="btn btn-success btn-lg w-100">Post Job Opportunity</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Find Jobs Section -->
        <section id="findJobs" class="view-section d-none">
            <h2 class="mb-4">Find Available Jobs</h2>
            
            <div class="card shadow-sm border-0 mb-4 bg-light">
                <div class="card-body">
                    <form id="filterForm" class="row g-3">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Filter by Skill</label>
                            <select id="filterSkill" class="form-select form-select-lg">
                                <option value="All">All Skills</option>
                                <option value="Plumber">Plumber</option>
                                <option value="Electrician">Electrician</option>
                                <option value="Painter">Painter</option>
                                <option value="Carpenter">Carpenter</option>
                                <option value="Mazdoor">Mazdoor / Helper</option>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label fw-semibold">Filter by Location</label>
                            <input type="text" id="filterLocation" class="form-control form-control-lg" placeholder="Enter City or Pincode">
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary btn-lg w-100"><i class="bi bi-search"></i> Filter</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="row" id="jobListings">
                <!-- Job cards injected via JS -->
            </div>
            
            <div id="noJobsMessage" class="alert alert-info d-none text-center p-5 fs-5">
                <i class="bi bi-emoji-frown fs-1 d-block mb-3"></i>
                No jobs found matching your criteria. Try adjusting filters or check back later!
            </div>
        </section>
        <!-- Workers List Section -->
        <section id="workers" class="view-section d-none">
            <h2 class="mb-4">Registered Workers Directory</h2>
            <div class="row" id="workerListings">
                <!-- Worker cards injected via JS -->
            </div>
            <div id="noWorkersMessage" class="alert alert-info d-none text-center p-5 fs-5">
                <i class="bi bi-people fs-1 d-block mb-3"></i>
                No workers registered yet. Be the first to register!
            </div>
        </section>
    </div>
    <!-- OTP Verification Modal -->
    <div class="modal fade" id="otpModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Aadhaar Verification Simulation</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <i class="bi bi-phone-vibrate fs-1 text-primary d-block mb-3"></i>
                    <p class="fs-5">An OTP has been sent to your Aadhaar linked mobile number.</p>
                    <p class="text-muted small mb-4">(Since this is a prototype, enter any number sequence like 123456)</p>
                    <input type="text" id="otpInput" class="form-control form-control-lg text-center fs-3 tracking-widest" placeholder="• • • • • •" maxlength="6" autocomplete="off">
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-primary btn-lg w-100" onclick="verifyOTP()">Verify & Complete Profile</button>
                </div>
            </div>
        </div>
    </div>
    <!-- JS Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="script.js"></script>
</body>
</html>
/* General Resets and Typography */
body {
    font-family: 'Inter', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    background-color: #f8f9fa;
    color: #333;
}
/* Navbar */
.navbar-brand {
    font-size: 1.5rem;
    letter-spacing: -0.5px;
}
/* Hero Section */
.hero-section {
    background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
    box-shadow: inset 0 -10px 20px rgba(0,0,0,0.05);
}
/* Hover effects */
.hover-white:hover {
    color: white !important;
}
/* Cards Animation */
.card {
    transition: transform 0.25s ease-in-out, box-shadow 0.25s ease-in-out;
}
.job-card:hover, .worker-card:hover, .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
}
/* Badges */
.badge-verified {
    background-color: #e8f5e9;
    color: #2e7d32;
    padding: 0.4em 0.8em;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    box-shadow: 0 2px 5px rgba(46,125,50,0.1);
}
.badge-verified::before {
    content: "\F26A"; /* Bootstrap icon code for shield-check */
    font-family: "bootstrap-icons";
    font-size: 0.9rem;
}
.skill-badge {
    background-color: #e3f2fd;
    color: #0d6efd;
    font-weight: 600;
    font-size: 0.8rem;
    padding: 0.5em 1em;
}
.urgency-badge {
    font-size: 0.75rem;
    padding: 0.4em 0.8em;
    border-radius: 20px;
}
/* WhatsApp Button */
.whatsapp-btn {
    background-color: #25D366;
    color: white;
    font-weight: 600;
    border: none;
    transition: all 0.2s;
}
.whatsapp-btn:hover {
    background-color: #128C7E;
    color: white;
    transform: scale(1.02);
}
/* Worker Profile Image Overlay (simulated with CSS circles) */
.worker-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid white;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
.worker-avatar-placeholder {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6f42c1, #0d6efd);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: bold;
    border: 3px solid white;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
/* Form inputs */
.form-control, .form-select {
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    border: 1px solid #dee2e6;
}
.form-control:focus, .form-select:focus {
    border-color: #8da4f1;
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
}
/* Map specific override */
#map.d-none {
    /* Need to handle d-none for leaflet map accurately */
    display: none !important;
}
#map {
    display: flex !important;
    flex-direction: column;
}
